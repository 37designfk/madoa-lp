---
---

<section class="py-16 md:py-24 bg-primary-600 text-white">
  <div class="max-w-5xl mx-auto px-4">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <!-- Left: Window illustration -->
      <div class="flex justify-center">
        <div class="relative w-full max-w-sm">
          <!-- Subsidy badge -->
          <div class="absolute -top-4 -left-2 z-10 bg-accent-500 text-gray-900 rounded-full w-40 h-40 flex flex-col items-center justify-center shadow-lg transform -rotate-6">
            <span class="text-xs font-bold">先進的窓リノベ2026</span>
            <span class="text-sm font-bold">最大</span>
            <span class="text-4xl font-bold leading-none">200<span class="text-lg">万円</span></span>
            <span class="text-xs font-bold">補助が受けられます！</span>
          </div>

          <svg viewBox="0 0 360 280" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full mt-16">
            <!-- Before window (left) -->
            <text x="60" y="20" font-size="12" fill="white" text-anchor="middle" font-weight="bold">Before</text>
            <!-- Window frame -->
            <rect x="15" y="30" width="100" height="140" rx="3" fill="white" stroke="#94a3b8" stroke-width="3"/>
            <line x1="65" y1="30" x2="65" y2="170" stroke="#94a3b8" stroke-width="2"/>
            <line x1="15" y1="100" x2="115" y2="100" stroke="#94a3b8" stroke-width="2"/>
            <!-- Cold air arrows -->
            <path d="M30 55 L20 55" stroke="#60a5fa" stroke-width="1.5" stroke-dasharray="3 2"/>
            <path d="M30 75 L15 75" stroke="#60a5fa" stroke-width="1.5" stroke-dasharray="3 2"/>
            <text x="5" y="58" font-size="10" fill="#93c5fd">❄</text>
            <!-- Water drops (結露) -->
            <circle cx="40" cy="90" r="2" fill="#93c5fd" opacity="0.7"/>
            <circle cx="50" cy="95" r="1.5" fill="#93c5fd" opacity="0.7"/>
            <circle cx="80" cy="88" r="2" fill="#93c5fd" opacity="0.7"/>
            <circle cx="90" cy="93" r="1.5" fill="#93c5fd" opacity="0.7"/>
            <circle cx="45" cy="145" r="2" fill="#93c5fd" opacity="0.7"/>
            <circle cx="85" cy="150" r="1.5" fill="#93c5fd" opacity="0.7"/>

            <!-- Arrow -->
            <path d="M135 100 L160 100" stroke="white" stroke-width="3" marker-end="url(#arrowhead)"/>
            <defs>
              <marker id="arrowhead" markerWidth="10" markerHeight="7" refX="10" refY="3.5" orient="auto">
                <polygon points="0 0, 10 3.5, 0 7" fill="white"/>
              </marker>
            </defs>

            <!-- After window (right) - with inner window -->
            <text x="260" y="20" font-size="12" fill="white" text-anchor="middle" font-weight="bold">After</text>
            <!-- Outer window frame -->
            <rect x="190" y="30" width="130" height="140" rx="3" fill="white" stroke="#0094DE" stroke-width="3"/>
            <line x1="255" y1="30" x2="255" y2="170" stroke="#0094DE" stroke-width="2"/>
            <line x1="190" y1="100" x2="320" y2="100" stroke="#0094DE" stroke-width="2"/>
            <!-- Inner window (内窓) -->
            <rect x="200" y="38" width="110" height="55" rx="2" fill="#dbeafe" stroke="#0094DE" stroke-width="1.5" opacity="0.6"/>
            <rect x="200" y="107" width="110" height="55" rx="2" fill="#dbeafe" stroke="#0094DE" stroke-width="1.5" opacity="0.6"/>
            <!-- Sparkles -->
            <text x="210" y="75" font-size="14" fill="#0094DE">✦</text>
            <text x="280" y="75" font-size="10" fill="#0094DE">✦</text>
            <text x="240" y="145" font-size="12" fill="#0094DE">✦</text>
            <!-- Air gap label -->
            <rect x="325" y="65" width="30" height="50" rx="3" fill="none" stroke="white" stroke-width="1" stroke-dasharray="3 2"/>
            <text x="332" y="95" font-size="8" fill="white" writing-mode="tb">空気層</text>

            <!-- Labels below -->
            <text x="65" y="200" font-size="11" fill="#93c5fd" text-anchor="middle">単板ガラス</text>
            <text x="65" y="215" font-size="10" fill="#93c5fd" text-anchor="middle" opacity="0.7">結露・寒さ</text>

            <text x="255" y="200" font-size="11" fill="white" text-anchor="middle" font-weight="bold">内窓（二重窓）</text>
            <text x="255" y="215" font-size="10" fill="#bfdbfe" text-anchor="middle">断熱・結露防止・防音</text>

            <!-- Bottom comparison -->
            <rect x="15" y="235" width="330" height="35" rx="8" fill="white" opacity="0.15"/>
            <text x="180" y="258" font-size="12" fill="white" text-anchor="middle" font-weight="bold">内窓を設置するだけで、窓の断熱性能が大幅にアップ！</text>
          </svg>
        </div>
      </div>

      <!-- Right: Overview text -->
      <div>
        <p class="text-primary-200 text-sm font-bold mb-2 tracking-wider">SUBSIDY</p>
        <h2 class="text-2xl md:text-3xl font-bold mb-6">先進的窓リノベ2026の概要</h2>

        <p class="text-primary-100 leading-relaxed mb-6">
          国の先進的窓リノベ2026では、内窓設置・外窓交換・ガラス交換などの断熱リフォーム費用が最大200万円まで補助されます。補助額は窓の性能やサイズにより変わり、申請や受け取りは登録済みの窓リノベ事業者が代行する仕組みです。
        </p>

        <p class="text-accent-400 font-bold mb-6">全国で累計34万件超の申請があり、安心して利用できる補助金です</p>

        <!-- Stats -->
        <div class="grid grid-cols-2 gap-4 mb-6">
          <div class="bg-white/10 rounded-xl p-4 text-center backdrop-blur-sm">
            <p class="text-xs text-primary-200">2025年度補正予算</p>
            <p class="text-2xl font-bold">1,350<span class="text-sm">億円</span></p>
          </div>
          <div class="bg-white/10 rounded-xl p-4 text-center backdrop-blur-sm">
            <p class="text-xs text-primary-200">累計交付申請件数</p>
            <p class="text-2xl font-bold">345,291<span class="text-sm">件</span></p>
          </div>
          <div class="bg-white/10 rounded-xl p-4 text-center backdrop-blur-sm">
            <p class="text-xs text-primary-200">累計交付申請戸数</p>
            <p class="text-2xl font-bold">365,555<span class="text-sm">戸</span></p>
          </div>
          <div class="bg-white/10 rounded-xl p-4 text-center backdrop-blur-sm">
            <p class="text-xs text-primary-200">累計交付申請金額</p>
            <p class="text-2xl font-bold">約991<span class="text-sm">億円</span></p>
          </div>
        </div>

        <p class="text-xs text-primary-300">※公表値は交付申請・予約の累計など定義があります。対象可否・補助額は要件により異なります。</p>
      </div>
    </div>
  </div>
</section>
