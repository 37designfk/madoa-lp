---
const problems = [
  {
    text: '冬、窓際がとにかく寒い...暖房をつけても部屋が温まらない',
    iconPath: 'M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707',
  },
  {
    text: '窓の結露がひどく、カビが発生して掃除が大変',
    iconPath: 'M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z',
  },
  {
    text: '毎月の光熱費が高くて家計を圧迫している',
    iconPath: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1',
  },
  {
    text: '外の車や電車の音がうるさくて落ち着けない',
    iconPath: 'M15.536 8.464a5 5 0 010 7.072m2.828-9.9a9 9 0 010 12.728M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z',
  },
  {
    text: '窓のリフォームは高いと思って諦めていた',
    iconPath: 'M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
  },
];
---

<section class="py-16 md:py-24 bg-white">
  <div class="max-w-4xl mx-auto px-4">
    <h2 class="text-2xl md:text-3xl font-bold text-center mb-4">
      こんな<span class="text-primary-600">窓のお悩み</span>、ありませんか？
    </h2>
    <p class="text-gray-500 text-center mb-12">一つでも当てはまる方は、補助金で解決できるかもしれません</p>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      {problems.map((problem) => (
        <div class="flex items-start gap-4 bg-primary-50 rounded-xl p-5 border border-primary-100">
          <div class="flex-shrink-0 w-10 h-10 bg-primary-100 rounded-full flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d={problem.iconPath} />
            </svg>
          </div>
          <p class="text-base md:text-lg font-medium text-gray-700">{problem.text}</p>
        </div>
      ))}
    </div>

    <!-- Closing message -->
    <div class="mt-8 text-center bg-accent-500/10 rounded-xl p-6 border border-accent-500/20">
      <p class="text-lg md:text-xl font-bold text-gray-800">
        そのお悩み、<span class="text-primary-600">補助金を使えば最大200万円の補助</span>で解決できます！
      </p>
    </div>
  </div>
</section>
