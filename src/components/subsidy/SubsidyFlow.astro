---
const steps = [
  {
    number: 1,
    title: '無料相談・補助金対象チェック',
    description: 'お電話またはフォームからお問い合わせ。お住まいの窓が補助金対象かを無料で確認します。',
    iconPath: 'M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z',
  },
  {
    number: 2,
    title: '現地調査・採寸',
    description: 'スタッフがご自宅にお伺いし、窓の状態を確認。最適なプランをご提案します。',
    iconPath: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z',
  },
  {
    number: 3,
    title: 'お見積もり・ご契約',
    description: '補助金適用後の実質負担額を明示したお見積もりをご提示。ご納得いただいてからご契約。',
    iconPath: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
  },
  {
    number: 4,
    title: '補助金交付申請（当社が代行）',
    description: '必要書類の作成・提出はすべて当社が代行。お客様の手間はゼロです。',
    iconPath: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4',
  },
  {
    number: 5,
    title: '施工',
    description: '経験豊富な職人が丁寧に内窓を設置。作業時間は1箇所あたり約30分〜1時間です。',
    iconPath: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z',
  },
  {
    number: 6,
    title: '補助金交付・お受け取り',
    description: '工事完了後、補助金が交付されます。実質負担額のみのお支払いで完了です。',
    iconPath: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z',
  },
];
---

<section class="py-16 md:py-24 bg-gray-50">
  <div class="max-w-5xl mx-auto px-4">
    <h2 class="text-2xl md:text-3xl font-bold text-center mb-4">
      補助金申請から<span class="text-primary-600">工事完了まで</span>の流れ
    </h2>
    <p class="text-gray-500 text-center mb-12">面倒な申請手続きはすべてMADOAが代行します</p>

    <div class="relative">
      <!-- Connecting line (desktop) -->
      <div class="hidden md:block absolute top-8 left-[calc(16.67%+16px)] right-[calc(16.67%+16px)] h-0.5 bg-primary-200"></div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-6">
        {steps.map((step, index) => (
          <div class="relative flex flex-col items-center text-center">
            <!-- Mobile connecting line -->
            {index < steps.length - 1 && (
              <div class="md:hidden absolute top-full left-1/2 -translate-x-1/2 w-0.5 h-8 bg-primary-200"></div>
            )}

            <!-- Step number circle -->
            <div class={`relative z-10 w-14 h-14 ${step.number === 4 ? 'bg-accent-500' : 'bg-primary-600'} rounded-full flex items-center justify-center mb-4 shadow-md`}>
              <span class={`font-bold text-lg ${step.number === 4 ? 'text-gray-900' : 'text-white'}`}>{step.number}</span>
            </div>

            <!-- Icon -->
            <div class="mb-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d={step.iconPath} />
              </svg>
            </div>

            <!-- Text -->
            <h3 class="text-base font-bold text-gray-800 mb-2">{step.title}</h3>
            <p class="text-gray-600 text-sm leading-relaxed">{step.description}</p>

            {step.number === 4 && (
              <span class="mt-2 inline-block bg-accent-500/20 text-accent-700 text-xs font-bold px-3 py-1 rounded-full">
                お客様の手間ゼロ！
              </span>
            )}
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
