---
const base = import.meta.env.BASE_URL;
const steps = [
  {
    number: 1,
    title: '無料相談・対象確認',
    description: 'フォームまたはお電話でご相談。お住まいの状況をもとに、補助金の対象可否を確認します。',
    image: 'images/subsidy/flow-01.jpg',
  },
  {
    number: 2,
    title: '現地確認・窓の採寸',
    description: '実際の窓サイズ・状態を確認します。補助対象となる性能・工法を判断します。',
    image: 'images/subsidy/flow-02.jpg',
  },
  {
    number: 3,
    title: 'ご提案・お見積（無料）',
    description: '工事内容と補助金の概算をご案内します。内容にご納得いただいた場合のみ次へ進みます。',
    image: 'images/subsidy/flow-03.jpg',
  },
  {
    number: 4,
    title: 'ご契約・工事着手',
    description: '対象期間内で工事を実施します。必要な書類や写真は当社で管理します。',
    image: 'images/subsidy/flow-04.jpg',
  },
  {
    number: 5,
    title: '交付申請（当社が代行）',
    description: '補助金の申請は、登録事業者である当社が行います。',
    image: 'images/subsidy/flow-05.jpg',
  },
  {
    number: 6,
    title: '補助金の交付',
    description: '工事完了後、補助金が交付されます。申請から受取まで当社がサポートしますのでご安心ください。',
    image: 'images/subsidy/flow-06.jpg',
  },
];
---

<section class="py-16 md:py-24 bg-white">
  <div class="max-w-5xl mx-auto px-4">
    <p class="text-primary-600 text-sm font-bold text-center mb-2 tracking-wider">FLOW</p>
    <h2 class="text-2xl md:text-3xl font-bold text-center mb-12">補助金申請から工事までの流れ</h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {steps.map((step) => (
        <div class="text-center">
          <div class="relative mb-4">
            <img
              src={`${base}${step.image}`}
              alt={step.title}
              loading="lazy"
              class="w-full h-40 object-cover rounded-xl"
            />
            <div class="absolute -top-3 -left-3 w-10 h-10 bg-primary-600 rounded-full flex items-center justify-center shadow-md">
              <span class="text-white font-bold">{step.number}</span>
            </div>
          </div>
          <h3 class="text-lg font-bold text-gray-800 mb-2">{step.title}</h3>
          <p class="text-gray-600 text-sm leading-relaxed">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
