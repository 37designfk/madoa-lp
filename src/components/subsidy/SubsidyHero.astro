---
const base = import.meta.env.BASE_URL;
---

<section class="relative text-white overflow-hidden min-h-[600px] md:min-h-[700px]">
  <div class="absolute inset-0">
    <img src={`${base}images/subsidy/hero.jpg`} alt="内窓リフォーム施工例" class="w-full h-full object-cover object-center" width="1199" height="1600" fetchpriority="high" />
    <div class="absolute inset-0 bg-gradient-to-r from-primary-900/80 via-primary-900/50 to-primary-900/10"></div>
  </div>

  <div class="relative max-w-5xl mx-auto px-4 py-24 md:py-36">
    <div class="max-w-xl">
      <h1 class="text-4xl md:text-6xl font-bold leading-tight mb-6 animate-fade-in-up">
        補助金で、窓から<br />暮らしの質を上げる。
      </h1>
      <p class="text-xl md:text-2xl text-white/90 mb-8 animate-fade-in-up animate-delay-100 leading-relaxed">
        補助金を活用した窓リフォームで、<br />今の暮らしに合った、無理のない整え方を。
      </p>

      <!-- Trust badges -->
      <div class="flex flex-wrap gap-4 mb-8 animate-fade-in-up animate-delay-200">
        <div class="bg-white rounded-full w-36 h-36 flex flex-col items-center justify-center shadow-lg px-2 text-center">
          <span class="text-primary-600 text-xs font-bold leading-tight">先進的窓リノベ<br />2026対応</span>
          <span class="text-primary-600 text-xs mt-1">最大</span>
          <span class="text-accent-600 text-3xl font-bold leading-none">100<span class="text-base">万円</span></span>
        </div>
        <div class="bg-white rounded-full w-36 h-36 flex flex-col items-center justify-center shadow-lg px-2 text-center">
          <span class="text-primary-600 text-2xl font-bold leading-tight">見積<br />無料</span>
          <span class="text-gray-600 text-xs mt-2 leading-tight">しつこい営業<br />いたしません</span>
        </div>
        <div class="bg-white rounded-full w-36 h-36 flex flex-col items-center justify-center shadow-lg px-2 text-center">
          <span class="text-primary-600 text-xs font-bold">対応エリア</span>
          <span class="text-primary-600 text-2xl font-bold leading-tight mt-1">神戸市</span>
          <span class="text-primary-600 text-base font-bold">全域</span>
        </div>
      </div>

      <!-- Hero CTA -->
      <div class="flex flex-col sm:flex-row gap-3 animate-fade-in-up animate-delay-300">
        <a
          href="tel:078-597-2722"
          class="inline-flex items-center justify-center gap-2 bg-accent-500 hover:bg-accent-600 text-gray-900 font-bold py-5 px-8 rounded-full text-xl transition-all shadow-lg hover:shadow-xl hover:scale-105 hero-cta-pulse"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
          </svg>
          078-597-2722
        </a>
        <a
          href="https://lin.ee/TODO"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center justify-center gap-2 bg-[#06c755] hover:bg-[#05b04a] text-white font-bold py-5 px-8 rounded-full text-xl transition-all shadow-lg hover:shadow-xl hover:scale-105"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.318v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/>
          </svg>
          LINEで相談
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes heroPulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(252, 200, 0, 0.7); }
    50% { box-shadow: 0 0 0 12px rgba(252, 200, 0, 0); }
  }
  .hero-cta-pulse {
    animation: heroPulse 2s infinite;
  }
</style>
