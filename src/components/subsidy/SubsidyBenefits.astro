---
const base = import.meta.env.BASE_URL;
const benefits = [
  {
    title: '一年中、快適な室温をキープ',
    description: '窓からの熱の出入りを抑えることで、部屋の温度ムラを解消。夏は涼しく冬は暖かい、快適な空間が保てます。',
    image: 'images/subsidy/benefit-dannetsu.jpg',
    imageAlt: '窓リフォームによる断熱効果で室内温度を快適に保つイメージ',
  },
  {
    title: '結露を抑えて、お掃除がラクに',
    description: '断熱効果でイヤな結露の発生を抑制。毎朝の面倒な窓拭き作業や、湿気によるカビの悩みから解放されます。',
    image: 'images/subsidy/benefit-ketsuro.jpg',
    imageAlt: '内窓設置による結露防止効果とカビ対策のイメージ',
  },
  {
    title: '毎月の電気代の節約に',
    description: '冷暖房の効きが良くなるため、無駄なエネルギー消費をカット。毎月の電気代や暖房費の削減につながります。',
    image: 'images/subsidy/benefit-konetsuhi.jpg',
    imageAlt: '窓の断熱リフォームによる電気代削減と省エネ効果のイメージ',
  },
  {
    title: '騒音を低減し、防犯面でも安心',
    description: '気密性が高まることで、外の音が気になりにくい静かな環境へ。窓が破られにくくなり、防犯効果も高まります。',
    image: 'images/subsidy/benefit-bouon.jpg',
    imageAlt: '内窓設置による防音効果と防犯性能向上のイメージ',
  },
];
---

<section class="py-16 md:py-24 bg-gray-50">
  <div class="max-w-5xl mx-auto px-4">
    <p class="text-primary-600 text-sm font-bold text-center mb-2 tracking-wider">POINT</p>
    <h2 class="text-2xl md:text-3xl font-bold text-center mb-4">窓を整えると何が変わる？</h2>
    <p class="text-gray-600 text-center mb-12">「全部の窓を変える必要がある？」という相談が多いですが、<br class="hidden md:inline" />まずは"つらい場所だけ"からでもOKです。</p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {benefits.map((benefit) => (
        <div class="bg-white rounded-2xl overflow-hidden shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
          <img
            src={`${base}${benefit.image}`}
            alt={benefit.imageAlt}
            loading="lazy"
            class="w-full h-52 object-cover"
          />
          <div class="p-6">
            <h3 class="text-xl font-bold text-gray-800 mb-3">{benefit.title}</h3>
            <p class="text-gray-600 text-sm leading-relaxed">{benefit.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
