---
const base = import.meta.env.BASE_URL;
---

<section id="contact" class="py-16 md:py-24 bg-gray-50">
  <div class="max-w-4xl mx-auto px-4">
    <!-- Heading -->
    <div class="text-center mb-10">
      <p class="text-primary-600 text-sm font-bold mb-2">無料相談・お見積もり</p>
      <h2 class="text-2xl md:text-3xl font-bold mb-4">お電話・LINEで気軽にご相談</h2>
      <p class="text-gray-600 text-sm">窓の寒さ・暑さ・結露・外の音など、まずは「どの工事が近いか」と「補助金が使えそうか」を一緒に整理します。</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
      <!-- Left: Staff photo -->
      <div class="flex justify-center">
        <img
          src={`${base}images/subsidy/staff.jpg`}
          alt="株式会社三喜 MADOAのスタッフ"
          loading="lazy"
          class="w-full rounded-xl shadow-md object-cover aspect-[4/3]"
        />
      </div>

      <!-- Right: CTA buttons -->
      <div class="flex flex-col gap-4">
        <a
          href="tel:078-597-2722"
          class="w-full bg-accent-500 hover:bg-accent-600 text-gray-900 font-bold py-5 px-8 rounded-2xl text-lg transition-all shadow-lg hover:shadow-xl hover:scale-[1.02] text-center flex items-center justify-center gap-3"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" viewBox="0 0 20 20" fill="currentColor">
            <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
          </svg>
          <span>
            <span class="block text-2xl leading-tight">078-597-2722</span>
            <span class="text-xs font-medium opacity-90">受付 8:30〜17:30（土日祝休み）</span>
          </span>
        </a>

        <a
          href="https://lin.ee/TODO"
          target="_blank"
          rel="noopener"
          class="w-full bg-[#06c755] hover:bg-[#05b04a] text-white font-bold py-5 px-8 rounded-2xl text-lg transition-all shadow-lg hover:shadow-xl hover:scale-[1.02] text-center flex items-center justify-center gap-3"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" viewBox="0 0 24 24" fill="currentColor">
            <path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.318v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/>
          </svg>
          <span>
            <span class="block text-2xl leading-tight">LINEで相談</span>
            <span class="text-xs font-medium opacity-90">24時間受付・無料</span>
          </span>
        </a>
        <p class="text-gray-500 text-xs text-center">無理な営業は行いませんので、安心してご相談ください。</p>
      </div>
    </div>
  </div>
</section>
