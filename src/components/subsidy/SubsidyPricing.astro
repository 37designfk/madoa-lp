---
const pricingTable = [
  { size: '小', example: 'トイレ・浴室等', normal: '43,000', subsidy: '22,000', actual: '21,000' },
  { size: '中', example: '寝室・子供部屋等', normal: '61,000', subsidy: '34,000', actual: '27,000' },
  { size: '大', example: 'リビング掃出し窓等', normal: '113,000', subsidy: '52,000', actual: '61,000' },
  { size: '特大', example: '大型掃出し窓等', normal: '153,000', subsidy: '76,000', actual: '77,000' },
];

const examples = [
  {
    title: 'リビング 1箇所',
    rooms: 'リビング掃出し窓',
    normal: '113,000',
    actual: '61,000',
    saving: '52,000',
  },
  {
    title: 'リビング+寝室 2箇所',
    rooms: 'リビング掃出し窓 + 寝室',
    normal: '174,000',
    actual: '88,000',
    saving: '86,000',
  },
  {
    title: '家全体 6箇所セット',
    rooms: 'リビング+寝室+子供部屋+浴室 等',
    normal: '400,000',
    actual: '200,000',
    saving: '200,000',
  },
];
---

<section class="py-16 md:py-24 bg-white">
  <div class="max-w-5xl mx-auto px-4">
    <h2 class="text-2xl md:text-3xl font-bold text-center mb-4">
      補助金で<span class="text-primary-600">こんなにお得に！</span>
    </h2>
    <p class="text-gray-500 text-center mb-12">内窓設置の場合の価格イメージ</p>

    <!-- Price table -->
    <div class="overflow-x-auto mb-12">
      <table class="w-full bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        <thead>
          <tr class="bg-primary-600 text-white">
            <th class="py-3 px-4 text-left text-sm font-bold">サイズ</th>
            <th class="py-3 px-4 text-left text-sm font-bold">対象窓の例</th>
            <th class="py-3 px-4 text-right text-sm font-bold">通常価格</th>
            <th class="py-3 px-4 text-right text-sm font-bold">補助額</th>
            <th class="py-3 px-4 text-right text-sm font-bold">実質負担</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          {pricingTable.map((row) => (
            <tr class="hover:bg-gray-50">
              <td class="py-4 px-4 font-bold text-gray-800">{row.size}</td>
              <td class="py-4 px-4 text-sm text-gray-600">{row.example}</td>
              <td class="py-4 px-4 text-right text-gray-500 line-through">{row.normal}円〜</td>
              <td class="py-4 px-4 text-right text-primary-600 font-bold">-{row.subsidy}円</td>
              <td class="py-4 px-4 text-right text-accent-600 font-bold text-lg">{row.actual}円〜</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <!-- Example cards -->
    <h3 class="text-xl font-bold text-center mb-6">具体的な施工例</h3>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {examples.map((ex) => (
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 text-center hover:shadow-md transition-shadow">
          <h4 class="text-lg font-bold text-gray-800 mb-2">{ex.title}</h4>
          <p class="text-sm text-gray-500 mb-4">{ex.rooms}</p>
          <div class="mb-3">
            <span class="text-gray-400 line-through text-sm">通常 {ex.normal}円〜</span>
          </div>
          <div class="flex items-center justify-center gap-2 mb-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
            </svg>
          </div>
          <p class="text-3xl font-bold text-accent-600 mb-1">{ex.actual}<span class="text-lg">円〜</span></p>
          <p class="inline-block bg-primary-50 text-primary-700 text-sm font-bold px-3 py-1 rounded-full">{ex.saving}円お得！</p>
        </div>
      ))}
    </div>

    <p class="text-xs text-gray-400 text-center mt-8">※価格は目安です。窓のサイズ・仕様により異なります。正確な金額は無料見積でご確認ください。</p>
  </div>
</section>
