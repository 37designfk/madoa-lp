---
const cases = [
  {
    title: 'リビング掃出し窓 内窓設置',
    description: '断熱・結露対策として、リビングの掃出し窓に内窓を設置。冬場の寒さが大幅に改善されました。',
    normal: '113,000',
    subsidy: '52,000',
    actual: '61,000',
  },
  {
    title: '寝室+子供部屋 2箇所セット',
    description: '2階の寝室と子供部屋に内窓を設置。外の騒音がカットされ、睡眠環境が改善されました。',
    normal: '122,000',
    subsidy: '68,000',
    actual: '54,000',
  },
  {
    title: 'リビング+寝室+浴室 3箇所',
    description: '家の主要な窓をまとめて内窓設置。光熱費が月々約3,000円削減できました。',
    normal: '217,000',
    subsidy: '108,000',
    actual: '109,000',
  },
];
---

<section class="bg-gray-50 py-16 md:py-24">
  <div class="max-w-5xl mx-auto px-4">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">施工事例</h2>
      <p class="text-gray-600 text-lg">補助金を活用した内窓リフォームの実例</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {cases.map((item) => (
        <div class="bg-white rounded-xl shadow-md overflow-hidden border border-gray-100">
          <!-- Placeholder for future photo -->
          <div class="w-full h-48 bg-primary-50 flex items-center justify-center">
            <div class="text-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-primary-300 mx-auto mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              <p class="text-sm text-primary-400">施工写真準備中</p>
            </div>
          </div>
          <div class="p-5">
            <h3 class="text-lg font-bold text-gray-900 mb-2">{item.title}</h3>
            <p class="text-sm text-gray-600 leading-relaxed mb-4">{item.description}</p>
            <!-- Price comparison -->
            <div class="bg-gray-50 rounded-lg p-4">
              <div class="flex justify-between items-center mb-2">
                <span class="text-sm text-gray-500">通常価格</span>
                <span class="text-sm text-gray-400 line-through">{item.normal}円〜</span>
              </div>
              <div class="flex justify-between items-center mb-2">
                <span class="text-sm text-primary-600 font-medium">補助金</span>
                <span class="text-sm text-primary-600 font-bold">-{item.subsidy}円</span>
              </div>
              <div class="border-t border-gray-200 pt-2 flex justify-between items-center">
                <span class="text-sm font-bold text-gray-800">実質負担</span>
                <span class="text-xl font-bold text-accent-600">{item.actual}円〜</span>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Mini CTA -->
    <div class="text-center mt-12 bg-primary-50 rounded-xl p-8">
      <p class="text-gray-800 font-bold text-lg mb-2">あなたの窓も、補助金でお得にリフォームできます。</p>
      <p class="text-gray-600 text-sm mb-5">まずは無料でお見積もり。補助金対象かの確認もお任せください。</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href="tel:078-597-2722"
          class="inline-flex items-center justify-center gap-2 bg-green-600 hover:bg-green-700 text-white font-bold px-6 py-3 rounded-full transition-all hover:scale-105 text-sm"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 20 20" fill="currentColor">
            <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
          </svg>
          078-597-2722
        </a>
        <a
          href="#contact"
          class="inline-flex items-center justify-center gap-2 bg-accent-500 hover:bg-accent-600 text-black font-bold px-6 py-3 rounded-full transition-all hover:scale-105 text-sm"
        >
          無料で相談する
        </a>
      </div>
    </div>
  </div>
</section>
