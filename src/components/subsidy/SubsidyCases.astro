---
const base = import.meta.env.BASE_URL;
const cases = [
  {
    title: '寝室1か所の内窓リフォーム',
    badge: '内窓設置',
    tags: ['中サイズ × 1か所', '寝室向け', '補助金対象'],
    description: '冬の冷気や結露が気になる寝室の窓に、内窓を設置するプランです。まずは1部屋だけ断熱対策したい方におすすめです。',
    places: '1か所',
    normal: '61,000',
    subsidy: '34,000',
    actual: '27,000',
    note: '※中サイズ1か所を想定した参考価格です。現場状況により変動する場合があります。',
    image: 'images/subsidy/case-bedroom-1.jpg',
  },
  {
    title: 'リビング+寝室の内窓リフォーム',
    badge: '内窓設置',
    tags: ['大サイズ × 1', '中サイズ × 1', '2か所施工', '補助金対象'],
    description: 'リビングと寝室を同時に対策する、バランスのよい人気プランです。生活の中心と休む場所をまとめて快適に整えられます。',
    places: '2か所',
    normal: '174,000',
    subsidy: '86,000',
    actual: '88,000',
    note: '※大サイズ1か所＋中サイズ1か所を想定した参考価格です。現場状況により変動する場合があります。',
    image: 'images/subsidy/case-living-2.jpg',
  },
  {
    title: '寝室+子供部屋の内窓リフォーム',
    badge: '内窓設置',
    tags: ['中サイズ × 2か所', '2部屋施工', '補助金対象'],
    description: '家族の寝室環境をまとめて改善したい方向けのプランです。結露や寒さが気になる2部屋を無理なく対策できます。',
    places: '2か所',
    normal: '122,000',
    subsidy: '68,000',
    actual: '54,000',
    note: '※中サイズ2か所を想定した参考価格です。現場状況により変動する場合があります。',
    image: 'images/subsidy/case-bedroom-1.jpg',
  },
  {
    title: 'リビング1か所の内窓リフォーム',
    badge: '内窓設置',
    tags: ['大サイズ × 1か所', 'リビング向け', '補助金対象'],
    description: 'まずはリビングの1か所だけ試したい方におすすめのプランです。窓際の冷えを抑えながら、費用も抑えて始められます。',
    places: '1か所',
    normal: '113,000',
    subsidy: '52,000',
    actual: '61,000',
    note: '※大サイズ1か所を想定した参考価格です。現場状況により変動する場合があります。',
    image: 'images/subsidy/case-living-2.jpg',
  },
];
---

<section class="py-16 md:py-24 bg-gray-50">
  <div class="max-w-5xl mx-auto px-4">
    <p class="text-primary-600 text-sm font-bold text-center mb-2 tracking-wider">施工パターン</p>
    <h2 class="text-2xl md:text-3xl font-bold text-center mb-4">CASE STUDY</h2>
    <p class="text-gray-600 text-center mb-12">「どんな工事になるのか」「本当に変わるのか」は、事例を見るのが一番早いです。<br class="hidden md:inline" />あなたのお悩みに近いものからご覧ください。</p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {cases.map((item) => (
        <div class="bg-white rounded-xl shadow-md overflow-hidden border border-gray-100">
          <img
            src={`${base}${item.image}`}
            alt={item.title}
            loading="lazy"
            class="w-full h-56 object-cover"
          />
          <div class="p-6">
            <span class="inline-block bg-primary-600 text-white text-xs font-bold px-3 py-1 rounded-full mb-3">
              {item.badge}
            </span>
            <h3 class="text-xl font-bold text-gray-900 mb-3">{item.title}</h3>

            <div class="flex flex-wrap gap-2 mb-4">
              {item.tags.map((tag) => (
                <span class="text-xs bg-gray-100 text-gray-600 px-3 py-1 rounded-full border border-gray-200">{tag}</span>
              ))}
            </div>

            <p class="text-sm text-gray-600 leading-relaxed mb-4">{item.description}</p>

            <!-- Price table -->
            <div class="bg-primary-600 rounded-t-lg px-4 py-2">
              <p class="text-white text-sm font-bold text-center">参考価格イメージ</p>
            </div>
            <table class="w-full border border-gray-200 text-sm">
              <thead class="bg-gray-50">
                <tr>
                  <th class="py-2 px-3 text-center text-gray-600 font-medium border-b">内容</th>
                  <th class="py-2 px-3 text-center text-gray-600 font-medium border-b">通常価格</th>
                  <th class="py-2 px-3 text-center text-gray-600 font-medium border-b">補助金額</th>
                  <th class="py-2 px-3 text-center font-bold text-accent-600 border-b">実質価格</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td class="py-3 px-3 text-center"><span class="bg-primary-600 text-white text-xs font-bold px-2 py-0.5 rounded">{item.places}</span></td>
                  <td class="py-3 px-3 text-center text-gray-600">{item.normal}<span class="text-xs">円</span></td>
                  <td class="py-3 px-3 text-center text-primary-600 font-medium">{item.subsidy}<span class="text-xs">円</span></td>
                  <td class="py-3 px-3 text-center"><span class="text-2xl font-bold text-accent-600">{item.actual}</span><span class="text-xs text-gray-500">円</span></td>
                </tr>
              </tbody>
            </table>
            <p class="text-[10px] text-gray-400 mt-2">{item.note}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
