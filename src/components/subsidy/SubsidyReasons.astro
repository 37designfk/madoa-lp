---
const base = import.meta.env.BASE_URL;
const reasons = [
  {
    title: '窓の専門店としての技術力と50年以上の実績',
    description: '神戸で50年以上、窓ガラスのプロとして地域に根ざしたサービスを提供。年間リフォーム実績700件の経験と確かな技術で、安心・納得のリフォームをご提供します。',
    image: 'images/subsidy/reason-01.jpg',
    imageAlt: 'MADOAの窓の専門スタッフ',
  },
  {
    title: '地域に根差した実績と信頼',
    description: '神戸市全域で地域密着のサービスを展開。実店舗を構え、お客様との信頼関係を大切にしながら、一つひとつの工事を丁寧に行っています。',
    image: 'images/subsidy/reason-02.jpg',
    imageAlt: '株式会社三喜（madoa）の店舗外観と看板',
  },
  {
    title: '素材手配をスムーズに行える体制',
    description: '建材メーカーと直接取引し資材調達コストを抑えているため、窓交換工事をお得にご提供。費用面でのメリットがあります。',
    image: 'images/subsidy/reason-03.jpg',
    imageAlt: '自社倉庫でガラスをカットする職人',
  },
];
---

<section class="py-16 md:py-24 bg-white">
  <div class="max-w-5xl mx-auto px-4">
    <p class="text-primary-600 text-sm font-bold text-center mb-2 tracking-wider">POINT</p>
    <h2 class="text-2xl md:text-3xl font-bold text-center mb-4">
      MADOAが<span class="text-primary-600">選ばれる理由</span>
    </h2>
    <p class="text-gray-600 text-center mb-12">「同じ補助金を使うなら、経験と実績のある会社に任せたい」という方へ。</p>

    <div class="space-y-8">
      {reasons.map((reason, i) => (
        <div class={`flex flex-col ${i % 2 === 1 ? 'md:flex-row-reverse' : 'md:flex-row'} gap-8 items-center`}>
          <div class="md:w-1/2">
            <img
              src={`${base}${reason.image}`}
              alt={reason.imageAlt}
              loading="lazy"
              class="w-full h-64 object-cover rounded-2xl"
            />
          </div>
          <div class="md:w-1/2">
            <h3 class="text-xl font-bold text-gray-800 mb-4">{reason.title}</h3>
            <p class="text-gray-600 leading-relaxed">{reason.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
