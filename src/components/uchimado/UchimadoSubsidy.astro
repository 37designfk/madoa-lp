---
---

<section class="py-16 md:py-24 bg-primary-600 text-white">
  <div class="max-w-5xl mx-auto px-4">
    <div class="bg-white rounded-2xl p-8 md:p-12 text-gray-800">
      <div class="text-center mb-8">
        <span class="inline-flex items-center gap-2 bg-accent-500 text-gray-900 font-bold px-4 py-1.5 rounded-full text-sm mb-4">
          2026年度 補助金制度
        </span>
        <h2 class="text-2xl md:text-3xl font-bold">
          <span class="text-primary-600">先進的窓リノベ2026</span>で<br class="md:hidden" />内窓リフォームがお得に
        </h2>
      </div>

      <!-- 補助金額の目安 -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
        <div class="bg-primary-50 rounded-xl p-6 text-center">
          <p class="text-sm text-gray-500 font-bold mb-1">住宅の補助上限</p>
          <p class="text-4xl font-bold text-primary-600">100<span class="text-lg">万円/戸</span></p>
        </div>
        <div class="bg-primary-50 rounded-xl p-6 text-center">
          <p class="text-sm text-gray-500 font-bold mb-1">2026年度予算</p>
          <p class="text-4xl font-bold text-primary-600">1,125<span class="text-lg">億円</span></p>
        </div>
        <div class="bg-primary-50 rounded-xl p-6 text-center">
          <p class="text-sm text-gray-500 font-bold mb-1">申請期限</p>
          <p class="text-4xl font-bold text-primary-600">12/31<span class="text-lg">まで</span></p>
        </div>
      </div>

      <!-- 内窓の補助額例 -->
      <h3 class="text-lg font-bold text-gray-800 mb-4 text-center">内窓設置の補助額の目安</h3>
      <div class="overflow-x-auto mb-6">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-primary-600 text-white">
              <th class="px-4 py-3 text-left rounded-tl-lg">窓サイズ</th>
              <th class="px-4 py-3 text-center">SSグレード</th>
              <th class="px-4 py-3 text-center rounded-tr-lg">Sグレード</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b border-gray-100">
              <td class="px-4 py-3 font-bold">特大（引違い窓等）</td>
              <td class="px-4 py-3 text-center text-primary-600 font-bold">140,000円</td>
              <td class="px-4 py-3 text-center text-primary-600 font-bold">92,000円</td>
            </tr>
            <tr class="border-b border-gray-100 bg-gray-50">
              <td class="px-4 py-3 font-bold">大</td>
              <td class="px-4 py-3 text-center text-primary-600 font-bold">100,000円</td>
              <td class="px-4 py-3 text-center text-primary-600 font-bold">69,000円</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="px-4 py-3 font-bold">中</td>
              <td class="px-4 py-3 text-center text-primary-600 font-bold">58,000円</td>
              <td class="px-4 py-3 text-center text-primary-600 font-bold">40,000円</td>
            </tr>
            <tr>
              <td class="px-4 py-3 font-bold">小</td>
              <td class="px-4 py-3 text-center text-primary-600 font-bold">30,000円</td>
              <td class="px-4 py-3 text-center text-primary-600 font-bold">21,000円</td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- 緊急性 -->
      <div class="bg-accent-50 border-2 border-accent-400 rounded-xl p-4">
        <p class="text-center font-bold text-gray-900">
          <span class="text-accent-600">予算上限に達し次第終了</span> -- お早めにご相談ください
        </p>
        <p class="text-center text-sm text-gray-600 mt-1">2026年は内窓のAグレードが補助対象外になりました。SS・Sグレードでの申請がおすすめです。</p>
      </div>

      <p class="text-xs text-gray-400 mt-4 text-center">※補助額は要件により異なります。詳細はお問い合わせください。</p>
    </div>
  </div>
</section>
