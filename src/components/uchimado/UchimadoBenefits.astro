---
const benefits = [
  {
    title: '断熱効果',
    description: '既存の窓との間に空気層ができ、外気の影響を大幅に軽減。冬は暖かく、夏は涼しい室内環境を実現します。',
    stat: '約40%',
    statLabel: '暖房費削減',
    iconPath: 'M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z',
  },
  {
    title: '結露防止',
    description: '室内側のガラス表面温度が上がるため、不快な結露の発生を大幅に抑制。カビやダニの対策にも効果的です。',
    stat: '約70%',
    statLabel: '結露を軽減',
    iconPath: 'M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z',
  },
  {
    title: '防音効果',
    description: '二重窓構造により、外部騒音を大幅にカット。交通量の多い道路沿いでも静かな室内環境を実現します。',
    stat: '約-40dB',
    statLabel: '騒音カット',
    iconPath: 'M15.536 8.464a5 5 0 010 7.072m2.828-9.9a9 9 0 010 12.728M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z',
  },
  {
    title: '光熱費削減',
    description: '断熱性能の向上により、冷暖房の効率がアップ。年間を通じて光熱費の大幅な節約が期待できます。',
    stat: '年間約5万円',
    statLabel: '光熱費の節約',
    iconPath: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1',
  },
];
---

<section class="py-16 md:py-24 bg-gray-50">
  <div class="max-w-5xl mx-auto px-4">
    <h2 class="text-2xl md:text-3xl font-bold text-center mb-4">
      内窓リフォームの<span class="text-primary-600">4つのメリット</span>
    </h2>
    <p class="text-gray-500 text-center mb-12">今ある窓の内側にもう一枚窓を取り付けるだけで、暮らしが変わります</p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {benefits.map((benefit) => (
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 md:p-8 hover:shadow-md transition-shadow">
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-14 h-14 bg-primary-100 rounded-2xl flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d={benefit.iconPath} />
              </svg>
            </div>
            <div class="flex-1">
              <h3 class="text-xl font-bold text-gray-800 mb-2">{benefit.title}</h3>
              <p class="text-gray-600 text-sm leading-relaxed mb-3">{benefit.description}</p>
              <div class="inline-flex items-center gap-2 bg-primary-50 px-4 py-2 rounded-full">
                <span class="text-2xl font-bold text-primary-600">{benefit.stat}</span>
                <span class="text-sm text-gray-600">{benefit.statLabel}</span>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
