---
const base = import.meta.env.BASE_URL;
const cases = [
  {
    title: '店舗ガラスドア割れ替え',
    description: '強化ガラス 5mm / 店舗入口',
    detail: '店舗入口のガラスドアを新しい強化ガラスに交換。クリアな仕上がりで防犯性も向上しました。',
    image: 'images/case-door.webp',
    imageAlt: '店舗ガラスドア割れ替えの施工写真',
  },
  {
    title: '掃き出し窓ガラス割れ替え',
    description: '透明ガラス 5mm / 掃き出し窓',
    detail: '和室の掃き出し窓のガラスを交換。透明度の高い新しいガラスで明るい室内を取り戻しました。',
    image: 'images/case-sliding.webp',
    imageAlt: '掃き出し窓ガラス割れ替えの施工写真',
  },
  {
    title: '腰高窓ガラス割れ替え',
    description: '透明ガラス 3mm / 腰高窓',
    detail: 'マンションの腰高窓のガラスを交換。きれいなガラスで見通しも良くなりました。',
    image: 'images/case-window.webp',
    imageAlt: '腰高窓ガラス割れ替えの施工写真',
  },
];
---

<section id="cases" class="bg-white py-16 md:py-24">
  <div class="max-w-5xl mx-auto px-4">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">施工事例</h2>
      <p class="text-gray-600 text-lg">実際の施工事例をご紹介します</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {cases.map((item) => (
        <div class="bg-white rounded-xl shadow-md overflow-hidden border border-gray-100">
          <picture>
            <source srcset={`${base}${item.image}`} type="image/webp" />
            <img
              src={`${base}${item.image.replace('.webp', '.png')}`}
              alt={item.imageAlt}
              loading="lazy"
              width="1200"
              height="654"
              class="w-full h-48 object-cover"
            />
          </picture>
          <div class="p-5">
            <h3 class="text-lg font-bold text-gray-900 mb-2">{item.title}</h3>
            <p class="text-sm text-primary-600 font-medium mb-2">{item.description}</p>
            <p class="text-sm text-gray-600 leading-relaxed">{item.detail}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Mini CTA -->
    <div class="text-center mt-12 bg-primary-50 rounded-xl p-8">
      <p class="text-gray-800 font-bold text-lg mb-2">あなたの窓も、きれいに直ります。</p>
      <p class="text-gray-600 text-sm mb-5">まずは無料でお見積もり。お気軽にご連絡ください。</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href="tel:078-597-2722"
          class="inline-flex items-center justify-center gap-2 bg-green-600 hover:bg-green-700 text-white font-bold px-6 py-3 rounded-full transition-all hover:scale-105 text-sm"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 20 20" fill="currentColor">
            <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
          </svg>
          078-597-2722
        </a>
        <a
          href="#contact"
          class="inline-flex items-center justify-center gap-2 bg-accent-500 hover:bg-accent-600 text-black font-bold px-6 py-3 rounded-full transition-all hover:scale-105 text-sm"
        >
          無料で相談する
        </a>
      </div>
    </div>
  </div>
</section>
